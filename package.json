{
  "name": "param-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/app/main.ts",
    "dev:worker": "bun --watch src/worker/main.ts",
    "start": "bun src/app/main.ts",
    "start:worker": "bun src/worker/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./tests/config.test.ts",
    "check": "bun run typecheck && bun run test",
    "doctor": "bun scripts/doctor.ts",
    "create-local-config": "bun scripts/create-local-config.ts"
  },
  "dependencies": {
    "@chat-adapter/state-pg": "^4.30.0",
    "@chat-adapter/telegram": "^4.30.0",
    "@clack/prompts": "^1.5.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chat": "^4.30.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
